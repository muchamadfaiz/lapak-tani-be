generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Outlet {
  id        String   @id @default(uuid())
  name      String
  address   String
  latitude  Float
  longitude Float
  phone     String?
  imageUrl  String?
  isActive  Boolean  @default(true)

  // Gudang besar (pusat pengadaan). Menyimpan stok memakai tabel yang sama
  // (product_outlets), tapi TIDAK ditampilkan di storefront & tak bisa dipesan.
  isWarehouse Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isWarehouse])
  @@map("outlets")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  price       Int // Rupiah (tanpa desimal) — harga JUAL (per satuan / per kg)
  costPrice   Int? // Rupiah — harga modal (opsional, internal)
  unit        String? // satuan: kg, gram, pcs, ikat, dll
  // Produk timbangan: dijual per berat (mis. per kg), qty boleh desimal (0,5 kg).
  soldByWeight Boolean @default(false)
  imageUrl    String?

  // Soft reference (TANPA FK lintas-modul) — divalidasi via CategoryContract.
  categoryId  String

  isAvailable Boolean  @default(true)

  // Produk unggulan (ditandai admin) — tampil di section "Produk Pilihan".
  isFeatured  Boolean  @default(false)

  // Soft delete: null = aktif. Produk terhapus disembunyikan dari query.
  deletedAt   DateTime?

  // Stok per outlet: satu produk dijual di semua outlet, stoknya beda-beda.
  outletStocks ProductOutlet[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@map("products")
}

// Stok sebuah produk pada sebuah outlet. Harga produk global (di Product);
// yang beda per outlet hanya stok. Dimiliki modul Product (via ProductRepository).
model ProductOutlet {
  id        String  @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Soft reference ke Outlet (TANPA FK lintas-modul) — divalidasi via OutletContract.
  outletId  String

  // Float agar mendukung produk timbangan (mis. 10.5 kg). Produk satuan tetap
  // memakai nilai bulat, jadi tetap ter-serialisasi sebagai bilangan bulat.
  stock     Float   @default(0)

  updatedAt DateTime @updatedAt

  @@unique([productId, outletId])
  @@index([outletId])
  @@map("product_outlets")
}

model Customer {
  id        String   @id @default(uuid())
  // Disimpan dalam format kanonik (lihat normalizePhone) agar konsisten.
  phone     String   @unique
  name      String?

  // Loyalty: saldo poin berjalan (1 poin / Rp1.000, earn saat order completed).
  points    Int      @default(0)

  // PIN 6 angka (bcrypt hash) untuk login cepat tanpa WA. null = belum set PIN.
  pinHash   String?

  orders            Order[]
  pointTransactions PointTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

// Buku besar poin (auditable, anti-drift). Dimiliki modul Order.
model PointTransaction {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])

  orderId      String? // order pemicu (untuk earn)
  type         String // earn | redeem
  amount       Int // poin bertambah (earn) — selalu positif untuk earn
  balanceAfter Int
  note         String?

  createdAt    DateTime @default(now())

  @@index([customerId])
  @@map("point_transactions")
}

model Order {
  id          String @id @default(uuid())
  orderNumber String @unique

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  // Soft reference lintas-modul (TANPA FK) — divalidasi via OutletContract.
  outletId    String

  status      String @default("pending") // pending, confirmed, processing, shipped, completed, cancelled

  // Opsi pengiriman: instant (10rb/km) | scheduled_morning | scheduled_afternoon (2rb/km).
  deliveryOption String @default("instant")

  subtotal      Int
  shippingCost  Int
  total         Int

  paymentMethod   String // transfer, cod/cash, qris/online, dll
  shippingAddress String  @db.Text
  notes           String? @db.Text

  // Bukti transfer manual yang diunggah pelanggan (URL gambar). Diverifikasi admin.
  paymentProofUrl String?
  paymentProofAt  DateTime?

  // ── Penjualan kasir (POS) ──
  // Asal transaksi: "online" (app/web pelanggan) | "pos" (kasir di outlet).
  // Dipakai memisahkan omzet toko vs online pada laporan.
  source          String @default("online")
  // Sesi kasir pemilik transaksi (hanya untuk source = "pos").
  shiftId         String?
  // Uang tunai yang diterima kasir (untuk struk & rekap kas). null bila non-tunai.
  amountPaid      Int?

  // Koordinat tujuan (opsional) untuk kalkulasi ongkir
  latitude    Float?
  longitude   Float?
  distanceKm  Float?

  items       OrderItem[]

  // Batas waktu pembayaran untuk order `pending` (auto-cancel bila lewat).
  expiresAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([outletId])
  @@index([status])
  @@map("orders")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String // soft reference ke user (penerima)
  title     String
  message   String   @db.Text
  type      String? // order, info, dll
  data      Json? // payload tambahan, mis. { orderId }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model OrderItem {
  id          String @id @default(uuid())

  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Soft reference ke Product (TANPA FK) + snapshot data saat order dibuat.
  productId   String
  productName String
  price       Int
  quantity    Float // Float untuk produk timbangan (mis. 0,5 kg)
  subtotal    Int

  @@map("order_items")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String

  roleId            String
  role              Role      @relation(fields: [roleId], references: [id])

  // Outlet tempat kasir bertugas (soft reference, tanpa FK lintas-modul).
  // null untuk ADMIN — admin tidak terikat satu outlet.
  outletId          String?

  isActive          Boolean   @default(true)
  emailVerifiedAt   DateTime?
  passwordChangedAt DateTime?

  profile                  Profile?
  refreshTokens            RefreshToken[]
  files                    File[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@map("users")
}

model Profile {
  id        String    @id @default(uuid())

  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName  String
  phone     String?
  address   String?
  avatarUrl String?
  birthDate DateTime?
  gender    Gender?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("profiles")
}

enum Gender {
  MALE
  FEMALE
}

model Role {
  id    String @id @default(uuid())
  name  String @unique

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model File {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  originalName String
  filename     String
  url          String
  mimetype     String
  size         Int

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("files")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("email_verification_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiredAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@map("refresh_tokens")
}

model Banner {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  imageUrl    String
  linkUrl     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("banners")
}

// Kode OTP (WhatsApp via Fonnte). codeHash = hash bcrypt (kode tak disimpan plain).
model OtpCode {
  id         String    @id @default(uuid())
  phone      String // format kanonik 62...
  codeHash   String
  purpose    String    @default("verify") // verify | login | dll
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose])
  @@map("otp_codes")
}

// "Login instan WhatsApp" (reverse-OTP): app buat sesi berkode, user kirim kode
// itu ke nomor WA bisnis, webhook Fonnte mengisi `phone` dari nomor pengirim.
model WaLoginSession {
  id        String   @id @default(uuid())
  code      String   @unique // nonce yang dikirim user via WA (single-use, singkat)
  phone     String? // diisi dari nomor pengirim saat pesan masuk
  status    String   @default("pending") // pending | verified
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([status])
  @@map("wa_login_sessions")
}

// Pengaturan aplikasi (key-value) yang bisa diubah admin tanpa deploy.
// Contoh: online_payment_enabled, bank_name, bank_account_number, bank_account_name.
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── Manajemen stok (MVP) ──
// Gudang = Outlet dengan isWarehouse=true, sehingga stoknya memakai tabel yang
// sama (product_outlets). Kiriman = perpindahan stok antar-outlet (gudang→outlet).

// Kiriman barang dari satu outlet/gudang ke outlet lain.
// Alur: sent (stok asal turun) → received (stok tujuan naik). Barang "di jalan"
// tidak dihitung di kedua sisi, sehingga tak ada stok ganda.
model StockShipment {
  id           String @id @default(uuid())
  shipmentNumber String @unique

  // Soft reference ke Outlet (tanpa FK lintas-modul), divalidasi via OutletContract.
  fromOutletId String // biasanya gudang
  toOutletId   String

  status       String @default("sent") // sent | received | cancelled
  note         String? @db.Text

  sentAt       DateTime  @default(now())
  receivedAt   DateTime?

  items        StockShipmentItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([toOutletId, status])
  @@index([fromOutletId])
  @@map("stock_shipments")
}

model StockShipmentItem {
  id         String @id @default(uuid())

  shipmentId String
  shipment   StockShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  productId  String
  // Snapshot nama agar riwayat tetap terbaca walau produk berubah/terhapus.
  productName String
  quantity   Float

  @@index([shipmentId])
  @@map("stock_shipment_items")
}

// Pengadaan: barang masuk ke gudang/outlet, lengkap dengan supplier & harga
// modal (untuk hitung margin). Menjadi sumber referensi movement `purchase_in`.
model StockProcurement {
  id                String @id @default(uuid())
  procurementNumber String @unique

  // Gudang/outlet tujuan barang masuk (soft reference ke Outlet).
  outletId      String

  supplier      String?
  invoiceNumber String?
  note          String? @db.Text

  /// Total harga modal seluruh item (Rupiah). 0 bila tidak diisi.
  totalCost     Int     @default(0)

  items         StockProcurementItem[]

  createdAt     DateTime @default(now())

  @@index([outletId, createdAt])
  @@map("stock_procurements")
}

model StockProcurementItem {
  id            String @id @default(uuid())

  procurementId String
  procurement   StockProcurement @relation(fields: [procurementId], references: [id], onDelete: Cascade)

  productId     String
  productName   String // snapshot agar riwayat tetap terbaca
  quantity      Float

  /// Harga modal per satuan (Rupiah). null = tidak dicatat.
  unitCost      Int?
  /// unitCost * quantity (0 bila unitCost null).
  subtotalCost  Int  @default(0)

  @@index([procurementId])
  @@map("stock_procurement_items")
}

// Sesi kasir (shift). Kasir membuka kas dengan modal awal, melayani penjualan,
// lalu menutup kas. Selisih kas dihitung dari penjualan TUNAI pada sesi ini.
model CashierShift {
  id          String @id @default(uuid())

  // Soft reference (tanpa FK lintas-modul).
  userId      String
  outletId    String

  status      String @default("open") // open | closed

  /// Modal kas awal (Rupiah).
  openingCash Int    @default(0)
  /// Kas fisik saat tutup, diinput kasir. null selama sesi masih terbuka.
  closingCash Int?

  note        String? @db.Text

  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  @@index([outletId, status])
  @@index([userId, status])
  @@map("cashier_shifts")
}

// Buku besar stok — sumber "riwayat" pergerakan barang (auditable).
// quantity: positif = masuk, negatif = keluar (dilihat dari sisi outletId).
// type: purchase_in | transfer_out | transfer_in | sale | sale_cancel | adjustment
model StockMovement {
  id        String @id @default(uuid())

  productId String
  outletId  String

  type      String // purchase_in | transfer_out | transfer_in | adjustment
  quantity  Float

  // Referensi asal-usul (mis. shipmentId) agar bisa ditelusuri.
  refType   String?
  refId     String?
  note      String? @db.Text

  createdAt DateTime @default(now())

  @@index([outletId, createdAt])
  @@index([productId, createdAt])
  @@map("stock_movements")
}
