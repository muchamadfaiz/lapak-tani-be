generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Outlet {
  id        String   @id @default(uuid())
  name      String
  address   String
  latitude  Float
  longitude Float
  phone     String?
  imageUrl  String?
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("outlets")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  price       Int // Rupiah (tanpa desimal) — harga jual
  costPrice   Int? // Rupiah — harga modal (opsional, internal)
  unit        String? // satuan: kg, gram, pcs, ikat, dll
  imageUrl    String?

  // Soft reference (TANPA FK lintas-modul) — divalidasi via CategoryContract/OutletContract.
  categoryId  String
  outletId    String

  stock       Int      @default(0)
  isAvailable Boolean  @default(true)

  // Produk unggulan (ditandai admin) — tampil di section "Produk Pilihan".
  isFeatured  Boolean  @default(false)

  // Soft delete: null = aktif. Produk terhapus disembunyikan dari query.
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([outletId])
  @@index([categoryId])
  @@map("products")
}

model Customer {
  id        String   @id @default(uuid())
  // Disimpan dalam format kanonik (lihat normalizePhone) agar konsisten.
  phone     String   @unique
  name      String?

  // Loyalty: saldo poin berjalan (1 poin / Rp1.000, earn saat order completed).
  points    Int      @default(0)

  orders            Order[]
  pointTransactions PointTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

// Buku besar poin (auditable, anti-drift). Dimiliki modul Order.
model PointTransaction {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])

  orderId      String? // order pemicu (untuk earn)
  type         String // earn | redeem
  amount       Int // poin bertambah (earn) — selalu positif untuk earn
  balanceAfter Int
  note         String?

  createdAt    DateTime @default(now())

  @@index([customerId])
  @@map("point_transactions")
}

model Order {
  id          String @id @default(uuid())
  orderNumber String @unique

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  // Soft reference lintas-modul (TANPA FK) — divalidasi via OutletContract.
  outletId    String

  status      String @default("pending") // pending, confirmed, processing, shipped, completed, cancelled

  subtotal      Int
  shippingCost  Int
  total         Int

  paymentMethod   String // transfer_bca, cod, qris, dll (manual)
  shippingAddress String  @db.Text
  notes           String? @db.Text

  // Koordinat tujuan (opsional) untuk kalkulasi ongkir
  latitude    Float?
  longitude   Float?
  distanceKm  Float?

  items       OrderItem[]

  // Batas waktu pembayaran untuk order `pending` (auto-cancel bila lewat).
  expiresAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([outletId])
  @@index([status])
  @@map("orders")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String // soft reference ke user (penerima)
  title     String
  message   String   @db.Text
  type      String? // order, info, dll
  data      Json? // payload tambahan, mis. { orderId }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model OrderItem {
  id          String @id @default(uuid())

  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Soft reference ke Product (TANPA FK) + snapshot data saat order dibuat.
  productId   String
  productName String
  price       Int
  quantity    Int
  subtotal    Int

  @@map("order_items")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String

  roleId            String
  role              Role      @relation(fields: [roleId], references: [id])

  isActive          Boolean   @default(true)
  emailVerifiedAt   DateTime?
  passwordChangedAt DateTime?

  profile                  Profile?
  refreshTokens            RefreshToken[]
  files                    File[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@map("users")
}

model Profile {
  id        String    @id @default(uuid())

  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName  String
  phone     String?
  address   String?
  avatarUrl String?
  birthDate DateTime?
  gender    Gender?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("profiles")
}

enum Gender {
  MALE
  FEMALE
}

model Role {
  id    String @id @default(uuid())
  name  String @unique

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model File {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  originalName String
  filename     String
  url          String
  mimetype     String
  size         Int

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("files")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("email_verification_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiredAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@map("refresh_tokens")
}

model Banner {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  imageUrl    String
  linkUrl     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("banners")
}

// Kode OTP (WhatsApp via Fonnte). codeHash = hash bcrypt (kode tak disimpan plain).
model OtpCode {
  id         String    @id @default(uuid())
  phone      String // format kanonik 62...
  codeHash   String
  purpose    String    @default("verify") // verify | login | dll
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose])
  @@map("otp_codes")
}
