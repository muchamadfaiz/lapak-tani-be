# Application
NODE_ENV=development
APP_PORT=3000
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SWAGGER_ENABLED=true

# Rate limiting (global, per IP). Default: 120 request / 60 detik.
# Saat load test, naikkan THROTTLE_LIMIT sementara (mis. 1000000) lalu kembalikan.
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# Database
# Password Postgres untuk docker-compose (service db & DATABASE_URL app dibaca dari sini).
# WAJIB diganti kuat untuk produksi. Ganti hanya saat volume fresh (docker compose down -v).
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_boilerplate?schema=public

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_REFRESH_EXPIRATION=7d

# File Upload
FILE_UPLOAD_DEST=./uploads
FILE_UPLOAD_MAX_SIZE=2097152

# Email
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@app.com

# Frontend
FRONTEND_URL=http://localhost:3000

# Midtrans (pembayaran online). Aktifkan: MIDTRANS_ENABLED=true + isi key dari dashboard Midtrans.
# Sandbox: pakai Server/Client Key sandbox & MIDTRANS_IS_PRODUCTION=false.
MIDTRANS_ENABLED=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Auto-batal order pending yg lewat batas bayar (jam). Default 24.
ORDER_PENDING_EXPIRE_HOURS=24

# OTP via WhatsApp (Fonnte). Aktifkan dengan OTP_ENABLED=true + isi FONNTE_TOKEN.
OTP_ENABLED=false
FONNTE_TOKEN=
OTP_CODE_LENGTH=6
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SEC=60

# Channel OTP: whatsapp (Fonnte) | sms (Twilio) | screen (tampil di layar, DEMO/tak aman)
OTP_CHANNEL=sms
# Twilio (SMS) — isi dari dashboard Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Provider jarak: haversine (default, gratis) | ors (OpenRouteService, perlu key)
DISTANCE_PROVIDER=haversine

# ── Asisten CS (Google Gemini) ──
# Kosong = fitur chat MATI dengan rapi (GET /api/chat/status -> enabled:false),
# jadi aman di-deploy sebelum kuncinya ada. Ambil kunci di https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model gratis: Flash / Flash-Lite. Model Pro TIDAK punya kuota gratis.
GEMINI_MODEL=gemini-3.5-flash-lite
# PERHATIAN: pada tier GRATIS, Google memakai isi percakapan untuk melatih
# produknya. Naikkan ke tier berbayar sebelum bot melayani pelanggan asli.
# Hanya untuk pengujian lokal (arahkan ke server tiruan):
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
